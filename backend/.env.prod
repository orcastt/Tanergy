# Production environment — copy to .env.prod and fill in real values
# NEVER commit this file with real secrets

APP_ENV=production
APP_SECRET_KEY=<generate-with-openssl-rand-hex-32>

FRONTEND_URL=https://app.tangent.ai
ADMIN_URL=https://admin.tangent.ai

DATABASE_URL=postgresql+asyncpg://tangent:${POSTGRES_PASSWORD}@postgres:5432/tangent_db
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=<generate-with-openssl-rand-hex-32>
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# AI Provider Keys
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEEKAI_API_KEY=
GEMINI_API_KEY=
GLM_API_KEY=
TAVILY_API_KEY=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tangent.ai

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
