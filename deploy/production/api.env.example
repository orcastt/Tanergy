# Copy to deploy/production/api.env on the production API host.
# Do not commit deploy/production/api.env.

APP_ENV=production

TANGENT_ASSET_STORAGE_DRIVER=s3-compatible
TANGENT_ASSET_METADATA_DRIVER=postgres
TANGENT_BOARD_STORAGE_DRIVER=postgres
TANGENT_POSTGRES_AUTO_CREATE_TABLES=0
TANGENT_FREE_BOARD_SNAPSHOT_LIMIT=100

DATABASE_URL=postgresql://user:password@host:5432/tangent_production
DATABASE_POOL_URL=postgresql://user:password@pooler-host:5432/tangent_production
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10
TANGENT_DATABASE_CONNECT_TIMEOUT=8
TANGENT_DATABASE_SLOW_QUERY_MS=200

TANGENT_REQUIRE_API_AUTH=1
TANGENT_ALLOWED_ORIGINS=https://app.example.com
CLERK_AUTHORIZED_PARTIES=https://app.example.com

CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
CLERK_JWKS_URL=

S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_BUCKET=tangent-production-assets
S3_ACCESS_KEY_ID=replace-with-production-access-key
S3_SECRET_ACCESS_KEY=replace-with-production-secret-key
S3_REGION=auto
S3_ADDRESSING_STYLE=path
S3_PUBLIC_BASE_URL=

RESEND_API_KEY=

# Current active split:
# - GEEKAI_API_KEY: balanced image routes today (GPT Image 2 / Jimeng / Seedream)
# - GEEKAI_NANO_BANANA_API_KEY: Nano Banana 2 official channel today
# Active text split:
# - GEEKAI_TEXT_API_KEY: analysis / chat / prompt optimizer
# Reserved for later wiring:
# - GEEKAI_VIDEO_API_KEY: future video split
GEEKAI_API_KEY=
GEEKAI_BASE_URL=https://geekai.co/api/v1
GEEKAI_NANO_BANANA_API_KEY=
GEEKAI_NANO_BANANA_BASE_URL=
GEEKAI_TEXT_API_KEY=
GEEKAI_TEXT_BASE_URL=https://geekai.co/api/v1
GEEKAI_VIDEO_API_KEY=
GEEKAI_VIDEO_BASE_URL=https://geekai.co/api/v1
