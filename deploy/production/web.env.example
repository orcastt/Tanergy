# Copy these values into the Vercel production environment.
# Production values must be separate from staging values.

NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_ASSET_BASE_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

CLERK_SECRET_KEY=
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/workspaces
CLERK_AFTER_SIGN_UP_URL=/workspaces
TANGENT_REQUIRE_WEB_AUTH=1

NEXT_PUBLIC_TANGENT_ENABLE_LOCAL_AI_BRIDGE=
NEXT_PUBLIC_TANGENT_ENABLE_LOCAL_ASSET_BRIDGE=
NEXT_PUBLIC_TANGENT_ENABLE_LOCAL_BOARD_BRIDGE=

NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.05
