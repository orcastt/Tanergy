# Copy into the staging server's private env store, then copy or symlink it to
# the active release at deploy/staging/api.env.
# Do not commit deploy/staging/api.env.

APP_ENV=staging
AUTH_PROVIDER=clerk

TANGENT_ASSET_STORAGE_DRIVER=s3-compatible
TANGENT_ASSET_METADATA_DRIVER=postgres
TANGENT_BOARD_STORAGE_DRIVER=postgres
TANGENT_POSTGRES_AUTO_CREATE_TABLES=0
TANGENT_FREE_BOARD_SNAPSHOT_LIMIT=100
TANGENT_BOARD_REALTIME_PERSIST_MODE=final_snapshot

DATABASE_URL=postgresql://user:password@host:5432/tangent_staging
DATABASE_POOL_URL=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
TANGENT_DATABASE_CONNECT_TIMEOUT=8
TANGENT_DATABASE_SLOW_QUERY_MS=200
TANGENT_REDIS_URL=redis://user:password@redis-host:6379/0
TANGENT_SECURITY_REDIS_ENABLED=1
TANGENT_REDIS_KEY_PREFIX=tangent-staging
TANGENT_HTTP_RATE_LIMIT_ENABLED=1
TANGENT_HTTP_RATE_LIMIT_PER_MINUTE=600
TANGENT_PUBLIC_RATE_LIMIT_PER_MINUTE=120
TANGENT_SHARE_PASSWORD_ATTEMPT_LIMIT=20
TANGENT_SHARE_PASSWORD_ATTEMPT_WINDOW_SECONDS=900
TANGENT_API_SLOW_RESPONSE_MS=1000
TANGENT_MEMORY_RSS_WARN_MB=768
TANGENT_MEMORY_LOG_INTERVAL_SECONDS=60
TANGENT_WAF_ENABLED=0
TANGENT_WAF_RATE_LIMITS_ENABLED=0
TANGENT_WAF_DASHBOARD_URL=
TANGENT_STATUS_PAGE_URL=
TANGENT_UPTIME_MONITOR_URL=
TANGENT_ALERT_EMAILS=
TANGENT_ALERT_WEBHOOK_URL=
TANGENT_ERROR_TRACKING_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
TANGENT_DATABASE_PITR_ENABLED=0
TANGENT_DATABASE_BACKUP_RPO_MINUTES=
TANGENT_DATABASE_BACKUP_RTO_MINUTES=
TANGENT_DATABASE_RESTORE_DRILL_AT=

TANGENT_DEV_USER_ID=
TANGENT_DEV_WORKSPACE_ID=
TANGENT_REQUIRE_API_AUTH=1
TANGENT_ALLOWED_ORIGINS=https://staging.example.com,http://localhost:3000
TANGENT_REQUIRE_WEBSOCKET_ORIGIN=1
TANGENT_ALLOWED_WEBSOCKET_ORIGINS=https://staging.example.com,http://localhost:3000
CLERK_AUTHORIZED_PARTIES=https://staging.example.com

CLERK_SECRET_KEY=replace-with-staging-clerk-secret-key
CLERK_JWT_ISSUER=https://example-staging.clerk.accounts.dev
CLERK_JWT_AUDIENCE=
CLERK_JWKS_URL=https://example-staging.clerk.accounts.dev/.well-known/jwks.json

S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_BUCKET=tangent-staging-assets
S3_ACCESS_KEY_ID=replace-with-staging-access-key
S3_SECRET_ACCESS_KEY=replace-with-staging-secret-key
S3_REGION=auto
S3_ADDRESSING_STYLE=path
S3_PUBLIC_BASE_URL=

RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Current active provider split:
# - GEEKAI_BALANCE_IMAGE_API_KEY: primary GPT Image 2 and Nano Banana 2 image lane
# - GEEKAI_OFFICIAL_IMAGE_API_KEY: optional secondary image lane for manual fallback
# - GEEKAI_TEXT_API_KEY: chat, prompt optimization, analysis and multimodal text routes
# - GEEKAI_VIDEO_API_KEY: reserved for future video work
GEEKAI_BALANCE_IMAGE_API_KEY=
GEEKAI_BALANCE_IMAGE_API_KEY_BASE_URL=https://geekai.co/api/v1
GEEKAI_OFFICIAL_IMAGE_API_KEY=
GEEKAI_OFFICIAL_IMAGE_API_KEY_BASE_URL=https://geekai.co/api/v1
GEEKAI_TEXT_API_KEY=
GEEKAI_TEXT_BASE_URL=https://geekai.co/api/v1
GEEKAI_VIDEO_API_KEY=
GEEKAI_VIDEO_BASE_URL=https://geekai.co/api/v1
GEEKAI_API_KEY=
GEEKAI_BASE_URL=https://geekai.co/api/v1
