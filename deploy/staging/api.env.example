# Copy to deploy/staging/api.env on the staging server.
# Do not commit deploy/staging/api.env.

TANGENT_ASSET_STORAGE_DRIVER=s3-compatible
TANGENT_ASSET_METADATA_DRIVER=postgres
TANGENT_BOARD_STORAGE_DRIVER=postgres
TANGENT_POSTGRES_AUTO_CREATE_TABLES=1

DATABASE_URL=postgresql://user:password@host:5432/tangent_staging

TANGENT_DEV_USER_ID=dev-user
TANGENT_DEV_WORKSPACE_ID=dev-workspace
TANGENT_REQUIRE_API_AUTH=0
TANGENT_ALLOWED_ORIGINS=https://staging.example.com,http://localhost:3000

S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_BUCKET=tangent-staging-assets
S3_ACCESS_KEY_ID=replace-with-staging-access-key
S3_SECRET_ACCESS_KEY=replace-with-staging-secret-key
S3_REGION=auto
S3_ADDRESSING_STYLE=path
S3_PUBLIC_BASE_URL=

GEEKAI_API_KEY=
GEEKAI_BASE_URL=https://geekai.co/api/v1
