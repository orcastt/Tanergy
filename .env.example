# TANGENT Web AI Image Canvas
# Copy to .env and fill real values locally. Never commit .env.

# Web app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ASSET_BASE_URL=
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_TANGENT_ENABLE_LOCAL_AI_BRIDGE=
NEXT_PUBLIC_TANGENT_ENABLE_LOCAL_ASSET_BRIDGE=
NEXT_PUBLIC_TANGENT_ENABLE_LOCAL_BOARD_BRIDGE=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# Backend / API
DATABASE_URL=postgresql://tangent:tangent@localhost:5432/tangent_web
JWT_SECRET=replace-with-local-secret
TANGENT_REDIS_URL=
TANGENT_SECURITY_REDIS_ENABLED=1
TANGENT_REDIS_KEY_PREFIX=tangent-local
TANGENT_HTTP_RATE_LIMIT_ENABLED=1
TANGENT_HTTP_RATE_LIMIT_PER_MINUTE=600
TANGENT_PUBLIC_RATE_LIMIT_PER_MINUTE=120
TANGENT_SHARE_PASSWORD_ATTEMPT_LIMIT=20
TANGENT_SHARE_PASSWORD_ATTEMPT_WINDOW_SECONDS=900
TANGENT_API_SLOW_RESPONSE_MS=1000
TANGENT_MEMORY_RSS_WARN_MB=0
TANGENT_MEMORY_LOG_INTERVAL_SECONDS=60
TANGENT_STATUS_PAGE_URL=
TANGENT_ALERT_EMAILS=
TANGENT_ALERT_WEBHOOK_URL=
TANGENT_ERROR_TRACKING_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# AI provider keys stay server-side only.
# Current active provider split is GeekAI-first:
# - GEEKAI_BALANCE_IMAGE_API_KEY: primary GPT Image 2 and Nano Banana 2 image lane
# - GEEKAI_OFFICIAL_IMAGE_API_KEY: optional secondary image lane kept for manual fallback
# - GEEKAI_TEXT_API_KEY: chat / prompt optimizer / analysis
# - GEEKAI_VIDEO_API_KEY: reserved for later wiring
#
GEEKAI_BALANCE_IMAGE_API_KEY=
GEEKAI_BALANCE_IMAGE_API_KEY_BASE_URL=https://geekai.co/api/v1
GEEKAI_OFFICIAL_IMAGE_API_KEY=
GEEKAI_OFFICIAL_IMAGE_API_KEY_BASE_URL=https://geekai.co/api/v1
GEEKAI_TEXT_API_KEY=
GEEKAI_TEXT_BASE_URL=https://geekai.co/api/v1
GEEKAI_VIDEO_API_KEY=
GEEKAI_VIDEO_BASE_URL=https://geekai.co/api/v1
GEEKAI_API_KEY=
GEEKAI_BASE_URL=https://geekai.co/api/v1

# Legacy Jiekou env names are comment-only rollback history.
# JIEKOU_IMAGE_KEY=
# JIEKOU_IMAGE_BASE_URL=https://api.jiekou.ai/v3
# JIEKOU_TEXT_KEY=
# JIEKOU_TEXT_BASE_URL=https://api.jiekou.ai/openai/v1
# JIEKOU_VIDEO_KEY=
# JIEKOU_VIDEO_BASE_URL=https://api.jiekou.ai/v3

# Object storage for generated/exported/merged images
TANGENT_ASSET_STORAGE_DRIVER=local-dev
TANGENT_ASSET_METADATA_DRIVER=object-storage
TANGENT_ASSET_STORAGE_DIR=.tangent-assets
TANGENT_BOARD_STORAGE_DRIVER=local-dev
TANGENT_BOARD_STORAGE_DIR=.tangent-boards
TANGENT_POSTGRES_AUTO_CREATE_TABLES=1
TANGENT_DEV_USER_ID=dev-user
TANGENT_DEV_WORKSPACE_ID=dev-workspace
TANGENT_REQUIRE_API_AUTH=0
TANGENT_REQUIRE_WEB_AUTH=0
TANGENT_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
TANGENT_REQUIRE_WEBSOCKET_ORIGIN=0
TANGENT_ALLOWED_WEBSOCKET_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100

# Clerk Auth. Enable TANGENT_REQUIRE_WEB_AUTH=1 when protected product routes should require sign-in.
AUTH_PROVIDER=clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/workspaces
CLERK_AFTER_SIGN_UP_URL=/workspaces
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional S3-compatible tuning. R2 commonly uses region=auto.
S3_REGION=auto
S3_ADDRESSING_STYLE=path
S3_PUBLIC_BASE_URL=

# Optional future services
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
