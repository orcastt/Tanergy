# TANGENT — Environment Variables Template
# 复制此文件为 .env，填入真实值
# .env 文件绝对不能提交到 Git

# ============================================
# 应用配置
# ============================================
APP_ENV=development             # development | production
APP_SECRET_KEY=                 # JWT 签名密钥（随机 32 位字符串，生产环境必须更换）
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173

# ============================================
# 数据库
# ============================================
DATABASE_URL=postgresql+asyncpg://tangent:password@localhost:5432/tangent_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# MinIO（对象存储）
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=tangent-assets
MINIO_USE_SSL=false             # 生产环境设为 true
MINIO_PUBLIC_URL=http://localhost:9000   # 用户访问资产的公开基础 URL

# ============================================
# AI API Keys
# ============================================

# Claude (Anthropic) - 用于 Chat / Optimize / Analysis 节点
ANTHROPIC_API_KEY=

# GeekAI - OpenAI-compatible relay provider for official routing
GEEKAI_API_KEY=

# Midjourney - 用于 Image 节点
# 方案A: 官方 API
MIDJOURNEY_API_KEY=
MIDJOURNEY_API_URL=https://api.midjourney.com/v1

# 方案B: useapi.net 代理（如果没有官方 API）
# USEAPI_TOKEN=
# USEAPI_DISCORD_TOKEN=

# Google Imagen 3 (Vertex AI)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=    # 服务账号 JSON 文件路径

# ============================================
# 搜索 API
# ============================================
TAVILY_API_KEY=                 # Search 节点使用

# ============================================
# 认证
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET_KEY=                 # 与 APP_SECRET_KEY 可相同，建议单独设置
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ============================================
# 邮件发送（验证码）
# ============================================
# 选择 Resend 或 SendGrid 之一

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tangent.app

# SendGrid（备用）
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# ============================================
# Stripe（订阅支付）
# ============================================
STRIPE_SECRET_KEY=              # sk_test_xxx（测试）/ sk_live_xxx（生产）
STRIPE_PUBLISHABLE_KEY=         # pk_test_xxx（前端用）
STRIPE_WEBHOOK_SECRET=          # whsec_xxx（Stripe Dashboard 获取）

# Stripe 套餐 Price ID（在 Stripe Dashboard 创建）
STRIPE_PRICE_STARTER_MONTHLY=   # price_xxx
STRIPE_PRICE_PRO_MONTHLY=       # price_xxx
STRIPE_PRICE_TEAM_MONTHLY=      # price_xxx

# ============================================
# 执行限额配置
# ============================================
FREE_PLAN_WEEKLY_SECONDS=1800    # 30 分钟
STARTER_PLAN_WEEKLY_SECONDS=18000  # 5 小时
PRO_PLAN_WEEKLY_SECONDS=72000    # 20 小时
TEAM_PLAN_WEEKLY_SECONDS=288000  # 80 小时

# ============================================
# 文件上传限制
# ============================================
MAX_IMAGE_SIZE_MB=20
MAX_VIDEO_SIZE_MB=500
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
